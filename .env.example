# --- AI configuration (all optional; the app works fully offline without it) ---

# RECOMMENDED (production): use the serverless proxy so the key stays server-side.
# Set this flag to "1" to route AI calls through /api/claude, and set the actual
# key as ANTHROPIC_API_KEY in your Vercel project (NOT prefixed with VITE_, so it
# never reaches the browser).
VITE_AI_PROXY=

# LOCAL DEV ONLY: call Anthropic directly from the browser with this key.
# Convenient for `npm run dev`, but the key is exposed to the client — never use
# this in a public deployment.
VITE_ANTHROPIC_API_KEY=

# Server-side key read by the /api/claude serverless function (set in Vercel).
# Listed here for reference; do not commit a real key.
# ANTHROPIC_API_KEY=
